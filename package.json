{
  "name": "booth-enhanser",
  "version": "0.1.0",
  "private": true,
  "description": "BOOTH購入者向けの非公式ブラウザ拡張機能(Manifest V3)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:firefox": "vite --config vite.config.firefox.ts",
    "build": "vite build",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "build:all": "npm run build && npm run build:firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "idb": "8.0.3",
    "webextension-polyfill": "0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.1",
    "@eslint/js": "10.0.1",
    "@types/webextension-polyfill": "0.12.5",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.6",
    "typescript": "7.0.2",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
